{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Assemble & Link (NASM + ld, Linux 64-bit)",
      "type": "shell",
      "command": "nasm -f elf64 ${file} -o $$   {fileDirname}/   $${fileBasenameNoExtension}.o && ld -o $$   {fileDirname}/   $${fileBasenameNoExtension}.exe $$   {fileDirname}/   $${fileBasenameNoExtension}.o",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Assemble & Link (NASM + gcc, easier for syscalls)",
      "type": "shell",
      "command": "nasm -f elf64 ${file} -o ${fileBasenameNoExtension}.o && gcc -no-pie -o ${fileBasenameNoExtension}.exe ${fileBasenameNoExtension}.o",
      "group": "build"
    }
  ]
}